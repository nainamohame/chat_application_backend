# =====================================================================
# Production (Render + Neon + Vercel)
# Set NODE_ENV=production on Render. Secure cookies and SameSite=None
# kick in automatically when isProd is true.
# =====================================================================
NODE_ENV=production
PORT=5000

# Neon Postgres connection string. When DATABASE_URL is set, src/config/db.js
# uses it (with SSL); the discrete DB_* vars below are ignored.
DATABASE_URL=postgresql://username:password@host/dbname?sslmode=require

# Generate two long random strings, one per secret. Do NOT reuse.
JWT_ACCESS_SECRET=your_access_secret
JWT_REFRESH_SECRET=your_refresh_secret

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# Comma-separated list is supported. In production set this to your
# Vercel frontend origin (no trailing slash). Locally you can omit this
# and the default http://localhost:5173 is used.
CLIENT_ORIGIN=https://your-frontend-domain.vercel.app
COOKIE_SECURE=true

# --- Email ---
# In production (Render, Railway, Fly.io, most PaaS) outbound SMTP is blocked,
# so we use Resend's HTTPS API. Sign up at https://resend.com/, create an API
# key, paste it here. For testing without a verified domain leave MAIL_FROM
# unset and the default "Chat App <onboarding@resend.dev>" is used (Resend
# delivers it ONLY to the account owner's email — verify a domain for prod).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
MAIL_FROM="Chat App <noreply@yourdomain.com>"

# Optional Gmail SMTP fallback. Used automatically when RESEND_API_KEY is
# missing AND SMTP_USER+SMTP_PASS are present (useful for local dev). The
# password must be a Google App Password, not your Gmail login password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Chat App <your_email@gmail.com>"

# =====================================================================
# Local development (only needed if DATABASE_URL is NOT set)
# =====================================================================
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=chat_app
DB_PORT=5432
